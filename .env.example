# Brave Search API — get a key at https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your_brave_api_key_here

# OpenRouter API — get a key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Synthesis model (default: openai/gpt-4o-mini — cheap and fast)
SYNTHESIS_MODEL=openai/gpt-4o-mini

# Lucid Agents payments (x402, Base Mainnet USDC)
# Your agent's private key (Base network wallet)
PRIVATE_KEY=your_private_key_here

# x402 facilitator URL (default: Lucid Agents hosted)
FACILITATOR_URL=https://facilitator.daydreams.systems

# Enable x402 payments (set to "true" in production)
ENABLE_PAYMENTS=false

# Agent metadata
AGENT_NAME=queryx
AGENT_VERSION=1.0.0
AGENT_DESCRIPTION="Agent-native web search API — pay-per-query in USDC via x402. Structured JSON results with AI synthesis."

# Server port (Railway sets this automatically)
PORT=3000
